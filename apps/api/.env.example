NODE_ENV=development
PORT=3000
APP_NAME=AI Pilot API
DATABASE_ENABLED=false
DATABASE_URL=postgresql://dealpilot:replace-with-a-random-password@localhost:5432/dealpilot
JWT_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AI_SERVICE_URL=http://localhost:8000
INTERNAL_TOKEN=replace-with-at-least-32-characters
VIEWER_TOKEN_SECRET=replace-with-at-least-32-characters
VIEWER_TOKEN_TTL_SECONDS=900
ADDRESS_SECRET_TTL_MS=1800000
CONTROL_LEASE_TTL_SECONDS=120
RUN_BROWSER_TTL_SECONDS=3600
EVENT_RETENTION_SECONDS=86400
DEALPILOT_PUBLIC_ORIGIN=http://localhost:8080
OBSERVABILITY_ENABLED=true
LOG_LEVEL=info
SLOW_REQUEST_MS=500
SLOW_CONTROLLER_MS=450
SLOW_SERVICE_MS=250
SLOW_REPOSITORY_MS=120
SLOW_QUERY_MS=100
N_PLUS_ONE_THRESHOLD=5
BLOCKING_OPERATION_MS=250
BLOCKING_EVENT_LOOP_UTILIZATION=0.75

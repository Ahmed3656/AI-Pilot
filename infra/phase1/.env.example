# Copy to infra/phase1/.env. The root runtime command generates strong local
# values for blank required secrets and keeps the resulting file untracked.
COMPOSE_PROJECT_NAME=dealpilot-phase1

# Egypt-only fixed runtime. The application timezone is always Africa/Cairo.
DEALPILOT_GATEWAY_PORT=8080
# Keep loopback for web/simulators. Use 0.0.0.0 only for a trusted LAN phone.
DEALPILOT_GATEWAY_BIND=127.0.0.1
DEALPILOT_PUBLIC_ORIGIN=http://localhost:8080
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_AUTH_REQUIRED=true

POSTGRES_DB=dealpilot
POSTGRES_USER=dealpilot
POSTGRES_PASSWORD=

NODE_ENV=production
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AI_SERVICE_URL=http://ai-service:8000
INTERNAL_TOKEN=
VIEWER_TOKEN_SECRET=
VIEWER_TOKEN_TTL_SECONDS=900
ADDRESS_SECRET_TTL_MS=1800000
CONTROL_LEASE_TTL_SECONDS=120
RUN_BROWSER_TTL_SECONDS=3600
EVENT_RETENTION_SECONDS=86400

AI_ENVIRONMENT=production
AI_LOG_LEVEL=INFO
AI_MODEL=openai/gpt-5.2
AI_VISION_FALLBACK_PROVIDER=openrouter
AI_VISION_FALLBACK_MODEL=
# Put the OpenRouter key in this ignored file. Compose grants it only to ai-service.
AI_OPENROUTER_API_KEY=
# Optional direct Gemini screenshot fallback. Keep this key only in the ignored runtime file.
AI_GEMINI_API_KEY=
AI_GEMINI_VISION_MODEL=gemini-3-flash-preview
AI_SELENIUM_REMOTE_URL=http://browser:4444/wd/hub
AI_CONTROL_API_URL=http://api:3000
AI_MAX_COMPUTER_STEPS=80
AI_MAX_VISUAL_RETRIES=3
AI_REQUEST_TIMEOUT_SECONDS=30

CADDY_API_UPSTREAM=api:3000
CADDY_VIEWER_UPSTREAM=browser:7900
SE_NODE_MAX_SESSIONS=1
SE_NODE_SESSION_TIMEOUT=3600
SE_SESSION_REQUEST_TIMEOUT=30

# Required only when the cloud-tunnel profile is selected.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_LOG_LEVEL=info

# Version pins move only after an explicit image-build/start validation.
POSTGRES_IMAGE=postgres:17-alpine
SELENIUM_IMAGE=selenium/standalone-chromium:4.45.0-20260606
CADDY_IMAGE=caddy:2.11.4-alpine
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.2

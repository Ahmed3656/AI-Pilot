# Copy to infra/phase1/.env, replace every change-me value, and keep that file uncommitted.
COMPOSE_PROJECT_NAME=dealpilot-phase1

# Loopback-only local gateway. The Cloudflare hostname remains the only public origin.
DEALPILOT_GATEWAY_PORT=8080
DEALPILOT_PUBLIC_ORIGIN=https://dealpilot-phase1.example.com
EXPO_PUBLIC_API_URL=https://dealpilot-phase1.example.com

POSTGRES_DB=dealpilot
POSTGRES_USER=dealpilot
POSTGRES_PASSWORD=change-me-use-a-long-random-database-password
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
INTERNAL_SERVICE_TOKEN=change-me-use-a-long-random-internal-token
VIEWER_AUTH_SHARED_SECRET=change-me-use-a-long-random-viewer-auth-secret

NODE_ENV=development
AI_ENVIRONMENT=development
AI_LOG_LEVEL=INFO
SELENIUM_SESSION_TIMEOUT_SECONDS=900
SELENIUM_REQUEST_TIMEOUT_SECONDS=30

# Remotely-managed Cloudflare Tunnel token. Required only for the cloud-tunnel profile.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_LOG_LEVEL=info

# Version pins can be advanced deliberately after testing.
POSTGRES_IMAGE=postgres:17-alpine
SELENIUM_IMAGE=selenium/standalone-chromium:4.46.0-20260707
CADDY_IMAGE=caddy:2.11.4-alpine
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.2

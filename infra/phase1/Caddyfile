{
	auto_https off
	admin off
}

:8080 {
	encode zstd gzip

	header {
		-Server
		Cache-Control "no-store"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	@gateway_health path /_gateway/health
	handle @gateway_health {
		respond `{"status":"ok","service":"dealpilot-phase1-gateway"}` 200 {
			close
		}
	}

	@viewer path /viewer /viewer/*
	handle @viewer {
		route {
			# Expanded forward-auth form is used because the frozen contract requires POST.
			reverse_proxy {$CADDY_API_UPSTREAM} {
				method POST
				rewrite /internal/v1/viewer/authorize
				header_up X-Forwarded-Method {method}
				header_up X-Forwarded-Uri {uri}
				header_up X-Internal-Token {$INTERNAL_TOKEN}

				@authorized status 2xx
				handle_response @authorized {
					copy_response_headers {
						include Set-Cookie
					}
					request_header X-DealPilot-Viewer-Mode {rp.header.X-Dealpilot-Viewer-Mode}
				}
			}

			@view_root {
				path /viewer /viewer/
				header X-DealPilot-Viewer-Mode view
			}
			redir @view_root /viewer/vnc.html?autoconnect=1&resize=scale&view_only=1&path=viewer/websockify 302

			@control_root path /viewer /viewer/
			redir @control_root /viewer/vnc.html?autoconnect=1&resize=scale&path=viewer/websockify 302

			uri strip_prefix /viewer
			reverse_proxy {$CADDY_VIEWER_UPSTREAM} {
				header_up -Authorization
				header_up -Cookie
				header_up -X-Internal-Token
				header_up -X-DealPilot-Viewer-Mode
				header_down -Server
				header_down Cache-Control "no-store"
			}
		}
	}

	@shopping_events {
		path_regexp events ^/api/v1/shopping/runs/[^/]+/events$
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @shopping_events {
		reverse_proxy {$CADDY_API_UPSTREAM}
	}

	handle /api/* {
		reverse_proxy {$CADDY_API_UPSTREAM}
	}

	handle /health* {
		reverse_proxy {$CADDY_API_UPSTREAM}
	}

	handle {
		respond "Not Found" 404
	}
}

{
  "name": "agent-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/mobile"
  ],
  "scripts": {
    "setup": "npm install && npm run setup:ai && npm run doctor",
    "setup:ai": "node scripts/setup-ai.mjs",
    "doctor": "node scripts/doctor.mjs",
    "start": "npm run dev",
    "dev": "concurrently --kill-others-on-fail --names API,MOBILE,AI --prefix-colors blue,magenta,green \"npm:dev:api\" \"npm:dev:mobile\" \"npm:dev:ai\"",
    "dev:api": "npm run start:dev --workspace @agent-platform/api",
    "dev:api:debug": "npm run start:debug --workspace @agent-platform/api",
    "dev:mobile": "npm run start --workspace @agent-platform/mobile",
    "dev:mobile:clear": "npm run start:clear --workspace @agent-platform/mobile",
    "dev:mobile:web": "npm run web --workspace @agent-platform/mobile",
    "dev:mobile:android": "npm run android --workspace @agent-platform/mobile",
    "dev:mobile:ios": "npm run ios --workspace @agent-platform/mobile",
    "dev:ai": "node scripts/run-python.mjs -m uvicorn agent_ai.main:app --app-dir services/ai-service/src --reload --port 8000",
    "start:api": "npm run start:prod --workspace @agent-platform/api",
    "start:ai": "node scripts/run-python.mjs -m uvicorn agent_ai.main:app --app-dir services/ai-service/src --host 0.0.0.0 --port 8000",
    "build": "npm run build:api && npm run typecheck:mobile && npm run build:ai",
    "build:all": "npm run build && npm run build:mobile:web",
    "build:api": "npm run build --workspace @agent-platform/api",
    "build:mobile:web": "npm run build:web --workspace @agent-platform/mobile",
    "build:ai": "node scripts/run-python.mjs -m compileall -q services/ai-service/src",
    "typecheck": "npm run typecheck:api && npm run typecheck:mobile",
    "typecheck:api": "npm run typecheck --workspace @agent-platform/api",
    "typecheck:mobile": "npm run typecheck --workspace @agent-platform/mobile",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "lint": "npm run lint:api && npm run lint:mobile && npm run lint:ai",
    "lint:fix": "npm run lint:fix --workspaces --if-present && npm run lint:ai:fix",
    "lint:api": "npm run lint --workspace @agent-platform/api",
    "lint:mobile": "npm run lint --workspace @agent-platform/mobile",
    "lint:ai": "node scripts/run-python.mjs -m ruff check services/ai-service",
    "lint:ai:fix": "node scripts/run-python.mjs -m ruff check --fix services/ai-service",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,json,md}\" \"scripts/**/*.mjs\" \"*.{json,md}\" \"docs/**/*.md\" && node scripts/run-python.mjs -m ruff format services/ai-service",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,json,md}\" \"scripts/**/*.mjs\" \"*.{json,md}\" \"docs/**/*.md\" && node scripts/run-python.mjs -m ruff format --check services/ai-service",
    "test": "npm run test:api && npm run test:ai",
    "test:api": "npm run test --workspace @agent-platform/api",
    "test:api:watch": "npm run test:watch --workspace @agent-platform/api",
    "test:api:coverage": "npm run test:cov --workspace @agent-platform/api",
    "test:ai": "node scripts/run-python.mjs -m pytest services/ai-service/tests",
    "health:check": "node scripts/health-check.mjs",
    "clean": "node scripts/clean.mjs",
    "mobile:doctor": "npm run doctor --workspace @agent-platform/mobile",
    "mobile:dependencies:check": "npm run dependencies:check --workspace @agent-platform/mobile",
    "mobile:dependencies:fix": "npm run dependencies:fix --workspace @agent-platform/mobile",
    "db:migration:create": "npm run migration:create --workspace @agent-platform/api --",
    "db:migration:generate": "npm run migration:generate --workspace @agent-platform/api --",
    "db:migration:show": "npm run migration:show --workspace @agent-platform/api",
    "db:migration:run": "npm run migration:run --workspace @agent-platform/api",
    "db:migration:revert": "npm run migration:revert --workspace @agent-platform/api",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "react": "19.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2",
    "react": "19.1.0"
  },
  "packageManager": "npm@10.9.2"
}
